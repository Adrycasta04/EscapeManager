@startuml activity_prenotazione
skinparam activityBackgroundColor LightCyan
skinparam activityBorderColor DarkCyan
skinparam activityDiamondBackgroundColor Wheat
skinparam activityDiamondBorderColor DarkGoldenRod

title Activity Diagram - UC1: Prenotazione Stanza

start

:Cliente accede al sistema;

:Sistema mostra catalogo stanze;

:Cliente seleziona stanza;

:Cliente seleziona data e ora;

:Cliente inserisce numero giocatori;

if (Numero giocatori <= capienza max?) then (Yes)

  :Sistema verifica disponibilità slot;

  if (Slot disponibile?) then (Yes)

    :Sistema calcola prezzo\n(Strategy Pattern);

    :Sistema mostra riepilogo\nprenotazione con prezzo;

    :Cliente conferma prenotazione;

    :Sistema crea prenotazione\n(Builder Pattern);

    :Sistema salva in database;

    :Sistema mostra conferma\ncon codice prenotazione;

    stop

  else (no - slot occupato)

    :Sistema mostra messaggio\n"Slot non disponibile";

    if (Cliente vuole iscriversi\na lista d'attesa?) then (Yes)

      :<<extend>>\nUC2: Iscrizione Lista d'Attesa;

      stop

    else (no)

      :Sistema torna al catalogo;

      stop

    endif

  endif

else (no - capienza superata)

  :Sistema mostra errore\n"Numero giocatori superiore\nalla capienza massima";

  :Cliente corregge\nnumero giocatori;

  -[#blue]-> :Cliente inserisce numero giocatori;

endif

@enduml
