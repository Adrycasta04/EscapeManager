@startuml package_diagram
skinparam linetype ortho
skinparam shadowing true
skinparam packageStyle folder
skinparam packageBackgroundColor LightCyan
skinparam packageBorderColor DarkCyan
skinparam nodesep 60
skinparam ranksep 50

package "it.unifi.escapemanager" {
    
    package "cli (View)" as view {
    }
    
    package "controllers (Control)" as controllers {
    }
    
    package "domain (Entity)" as domain {
    }
    
    package "dao (Persistence)" as dao {
    }
}

view ..> controllers : <<usa>>
controllers ..> domain : <<orchestra>>
controllers ..> dao : <<legge/scrive>>
dao ..> domain : <<mappa>>

note right of domain
    State, Strategy e
    Observer patterns
    sono implementati qui
end note

@enduml
