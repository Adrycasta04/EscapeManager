@startuml usecase_diagram
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor LightCyan
    BorderColor DarkCyan
    ArrowColor DarkCyan
}
skinparam actor {
    BackgroundColor Khaki
    BorderColor DarkGoldenRod
}

actor "Cliente" as C
actor "Game Master\n(Operatore)" as GM
actor "Admin" as A

rectangle "EscapeManager System" {
    
    ' --- Casi d'uso Cliente ---
    usecase "UC1\nPrenotazione Stanza" as UC_C1
    usecase "UC2\nIscrizione Lista d'Attesa" as UC_C2
    
    ' --- Casi d'uso Game Master ---
    usecase "UC3\nAggiornamento Stato Stanza" as UC_GM3
    
    ' --- Casi d'uso Admin ---
    usecase "UC4\nConfigurazione Tariffe Stanza" as UC_A2
}

' --- Relazioni Attori -> Casi d'uso ---
C --> UC_C1

GM --> UC_GM3

A --> UC_A2

' --- Relazioni <<extend>> (Flussi alternativi/opzionali) ---
UC_C2 .up.> UC_C1 : <<extend>>\n(se slot occupato)

@enduml
