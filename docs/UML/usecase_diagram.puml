@startuml usecase_diagram.puml
left to right direction
skinparam packageStyle rectangle
skinparam usecase {
    BackgroundColor LightCyan
    BorderColor DarkCyan
    ArrowColor DarkCyan
}
skinparam actor {
    BackgroundColor Khaki
    BorderColor DarkGoldenRod
}

actor "Cliente" as C
actor "Game Master\n(Operatore)" as GM
actor "Admin" as A

rectangle "EscapeManager System" {
    
    ' --- Casi d'uso condivisi/inclusi ---
    usecase "Autenticazione (Login)" as UC_Login
    
    ' --- Casi d'uso Cliente ---
    usecase "Ricerca Stanze" as UC_C1
    usecase "Prenotazione Stanza" as UC_C2
    usecase "Iscrizione Lista d'Attesa" as UC_C3
    usecase "Gestione Prenotazioni" as UC_C4
    
    ' --- Casi d'uso Game Master ---
    usecase "Visualizza Tabellone" as UC_GM1
    usecase "Controllo Sessione di Gioco" as UC_GM2
    usecase "Modifica Stato Stanza" as UC_GM3
    
    ' --- Casi d'uso Admin ---
    usecase "Gestione Filiali e Stanze" as UC_A1
    usecase "Configurazione Politiche di Prezzo" as UC_A2
}

' --- Relazioni Attori -> Casi d'uso ---
C --> UC_C1
C --> UC_C2
C --> UC_C4

GM --> UC_GM1
GM --> UC_GM2
GM --> UC_GM3

A --> UC_A1
A --> UC_A2

' --- Relazioni <<include>> (Dipendenze obbligatorie) ---
UC_C2 ..> UC_Login : <<include>>
UC_C4 ..> UC_Login : <<include>>
UC_GM1 ..> UC_Login : <<include>>
UC_GM2 ..> UC_Login : <<include>>
UC_GM3 ..> UC_Login : <<include>>
UC_A1 ..> UC_Login : <<include>>
UC_A2 ..> UC_Login : <<include>>

' --- Relazioni <<extend>> (Flussi alternativi/opzionali) ---
' L'iscrizione alla lista d'attesa è un'estensione del tentativo di prenotazione se lo slot è pieno
UC_C3 .up.> UC_C2 : <<extend>>\n(condizione: slot occupato)

@enduml